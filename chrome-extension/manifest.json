{
  "manifest_version": 3,
  "name": "ActivTrak Tab Activity",
  "version": "0.1.0",
  "description": "Tracks the active browser tab domain only. No history import.",
  "permissions": ["tabs", "alarms", "storage"],
  "host_permissions": ["http://localhost:3001/*", "http://127.0.0.1:3001/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "ActivTrak Tab Tracker",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
